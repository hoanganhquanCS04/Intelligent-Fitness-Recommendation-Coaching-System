{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "User Profile",
  "type": "object",
  "properties": {
    "id": {
      "type": "string",
      "format": "uuid"
    },
    "goal": {
      "type": "string",
      "enum": ["lose_weight", "build_muscle", "maintain_weight", "improve_endurance"],
      "description": "Mục tiêu tập luyện"
    },
    "weight": {
      "type": "number",
      "minimum": 20,
      "description": "Cân nặng hiện tại (kg)"
    },
    "height": {
      "type": "integer",
      "minimum": 50,
      "description": "Chiều cao (cm)"
    },
    "level": {
      "type": "string",
      "enum": ["beginner", "intermediate", "advanced"],
      "description": "Kinh nghiệm tập luyện"
    },
    "age": {
      "type": "integer",
      "minimum": 10,
      "description": "Tuổi của người dùng"
    },
    "equipment": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "Những dụng cụ người dùng có thể sử dụng"
    }
  },
  "required": ["id" , "goal", "weight", "height", "level", "age"]
}
{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Exercise",
  "type": "object",
  "properties": {
    "id": {
      "type": "string",
      "format": "uuid",
      "description": "Mã định danh duy nhất của bài tập"
    },
    "name": {
      "type": "string",
      "description": "Tên bài tập"
    },
    "muscle_group": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "minItems": 1,
      "description": "Các nhóm cơ mục tiêu"
    },
    "difficulty": {
      "type": "string",
      "enum": ["beginner", "intermediate", "advanced"],
      "description": "Mức độ khó của bài tập"
    },
    "equipment": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "Các dụng cụ cần thiết"
    },
    "duration": {
      "type": "integer",
      "minimum": 1,
      "description": "Thời gian thực hiện ước tính (tính bằng giây)"
    }
  },
  "required": ["id", "name", "muscle_group", "difficulty", "equipment", "duration"]
}
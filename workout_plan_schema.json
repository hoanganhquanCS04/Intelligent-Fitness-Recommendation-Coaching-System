{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Workout Plan",
  "type": "object",
  "properties": {
    "plan_id": {
      "type": "string",
      "format": "uuid",
      "description": "Mã định danh của kế hoạch"
    },
    "user_id": {
      "type": "string",
      "format": "uuid",
      "description": "Mã định danh của người dùng (liên kết với User Schema)"
    },
    "name": {
      "type": "string",
      "description": "Tên kế hoạch (VD: Tăng cơ ngực trong 4 tuần)",
      "minLength": 3
    },
    "goal": {
      "type": "string",
      "enum": ["lose_weight", "build_muscle", "maintain_weight", "improve_endurance"],
      "description": "Mục tiêu chính của kế hoạch"
    },
    "level": {
      "type": "string",
      "enum": ["beginner", "intermediate", "advanced"],
      "description": "Cấp độ yêu cầu của kế hoạch"
    },
    "duration_weeks": {
      "type": "integer",
      "minimum": 1,
      "description": "Tổng thời gian của kế hoạch tính bằng tuần"
    },
    "workouts": {
      "type": "array",
      "description": "Danh sách các buổi tập trong kế hoạch",
      "items": {
        "type": "object",
        "properties": {
          "workout_id": {
            "type": "string",
            "format": "uuid"
          },
          "day_number": {
            "type": "integer",
            "minimum": 1,
            "description": "Ngày tập thứ mấy trong kế hoạch (VD: Ngày 1, Ngày 2...)"
          },
          "name": {
            "type": "string",
            "description": "Tên buổi tập (VD: Upper Body, Leg Day)"
          },
          "exercises": {
            "type": "array",
            "description": "Danh sách bài tập trong buổi này",
            "items": {
              "type": "object",
              "properties": {
                "exercise_id": {
                  "type": "string",
                  "format": "uuid",
                  "description": "Liên kết với Exercise Schema"
                },
                "sets": {
                  "type": "integer",
                  "minimum": 1,
                  "description": "Số hiệp"
                },
                "reps": {
                  "type": "integer",
                  "minimum": 1,
                  "description": "Số lần lặp lại mỗi hiệp"
                },
                "rest_time": {
                  "type": "integer",
                  "minimum": 0,
                  "description": "Thời gian nghỉ giữa các hiệp (giây)"
                },
                "target_rpe": {
                  "type": "integer",
                  "minimum": 1,
                  "maximum": 10,
                  "description": "Rate of Perceived Exertion (độ khó cảm nhận mục tiêu, thang 1-10)"
                }
              },
              "required": ["exercise_id", "sets", "reps", "rest_time"]
            }
          }
        },
        "required": ["day_number", "name", "exercises"]
      }
    }
  },
  "required": [
    "plan_id",
    "user_id",
    "name",
    "goal",
    "level",
    "duration_weeks",
    "workouts"
  ]
}